# Supabase managed project (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SECRET_KEY=sb_secret_...

# Shared secret between the voice bridge and /api/agent/tools
AGENT_API_SECRET=generate-a-long-random-string
